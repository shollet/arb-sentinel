# Required environment variables for arb-sentinel
# Copy this file to .env and fill in the real values.
# Get an API key at https://the-odds-api.com

ODDS_API_KEY=your-api-key-here

# Discord webhook URL for arbitrage candidate notifications.
# Create one: Discord → Server Settings → Integrations → Webhooks.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token